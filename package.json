{
  "name": "token-manager",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    ".",
    "token-manager-stencil",
    "token-manager-vite"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "DOTENV_CONFIG_PATH=.env.local npx ts-node --transpile-only -r dotenv/config --project tsconfig.scripts.json scripts/seed.ts",
    "migrate:themes": "DOTENV_CONFIG_PATH=.env.local npx ts-node --transpile-only -r dotenv/config --project tsconfig.scripts.json scripts/migrate-theme-tokens.ts",
    "dev:stencil": "yarn workspace token-manager-stencil dev",
    "build:stencil": "yarn workspace token-manager-stencil build",
    "start:stencil": "yarn workspace token-manager-stencil start",
    "dev:vite": "yarn workspace token-manager-vite dev",
    "build:vite": "yarn workspace token-manager-vite build",
    "preview:vite": "yarn workspace token-manager-vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/supabase-js": "^2.99.1",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "mongodb": "^7.0.0",
    "mongoose": "^9.2.2",
    "next": "13.5.6",
    "react": "18.2.0",
    "react-colorful": "^5.6.1",
    "react-dom": "18.2.0",
    "react-resizable-panels": "^4.7.2",
    "style-dictionary": "^5.3.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "18.17.0",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "autoprefixer": "10.4.16",
    "dotenv": "^17.3.1",
    "eslint": "8.57.0",
    "eslint-config-next": "13.5.6",
    "postcss": "8.4.31",
    "tailwindcss": "3.3.0",
    "ts-node": "^10.9.2",
    "typescript": "5.2.2"
  },
  "packageManager": "yarn@4.9.1+sha512.f95ce356460e05be48d66401c1ae64ef84d163dd689964962c6888a9810865e39097a5e9de748876c2e0bf89b232d583c33982773e9903ae7a76257270986538"
}
